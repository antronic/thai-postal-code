{
  "name": "thai-postal-code",
  "version": "0.1.0",
  "description": "TypeScript library to autofill Thai province and district from postal code, with subdistrict listing support",
  "type": "module",
  "module": "./dist/index.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "bun": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "deno": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "browser": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "build:check": "tsc --noEmit",
    "dev": "tsup --config tsup.config.ts --watch",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "bun run build",
    "prepublishOnly": "bun run build:check && bun test && bun run build",
    "release": "npm publish --access public",
    "data:fetch": "bun run scripts/bundle-data.ts",
    "data:validate": "bun run scripts/validate-data.ts",
    "data:pipeline": "bun run data:fetch && bun run data:validate",
    "clean": "rm -rf dist",
    "build:check:scripts": "tsc --noEmit --project tsconfig.scripts.json",
    "build:check:all": "bun run build:check && bun run build:check:scripts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript-eslint": "^8.57.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "keywords": [
    "thailand",
    "thai",
    "postal-code",
    "zip-code",
    "address",
    "autofill",
    "province",
    "district",
    "subdistrict",
    "geocoding",
    "typescript"
  ],
  "author": {
    "email": "jirachai.c@outlook.com",
    "name": "Jirachai Chansivanon",
    "url": "https://jirachai.me"
  },
  "license": "MIT",
  "engines": {
    "node": ">=16",
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/antronic/thai-postal-code.git"
  },
  "bugs": {
    "url": "https://github.com/antronic/thai-postal-code.git/issues"
  },
  "homepage": "https://github.com/antronic/thai-postal-code.git#readme"
}
